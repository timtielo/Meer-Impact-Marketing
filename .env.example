# PostHog analytics (EU, cookieless). Set these in Netlify env vars before building.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=/ph

# Make.com lead webhooks — server-side only (NO Vite prefix, never shipped to the
# client). The submit-lead Netlify function reads these and forwards valid leads.
# Set both in Netlify env vars before deploying.
MAKE_ANALYSE_WEBHOOK=https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAKE_GUIDE_WEBHOOK=https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
