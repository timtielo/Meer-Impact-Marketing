# Copy to .env for local dev. In production these live in the Netlify env vars.
# Never commit the real .env.

# --- Lead delivery (submit-lead function) -----------------------------------
# The email is the guaranteed path: every valid form submission is mailed here.
# RESEND_API_KEY comes from the Resend dashboard (resend.com).
# LEAD_EMAIL_FROM must be a sender on a domain verified in that Resend account.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEAD_EMAIL_TO=lars@meerimpactmarketing.nl
LEAD_EMAIL_FROM=Meer Impact website <leads@meerimpactmarketing.nl>

# Optional pass-through. Set a webhook and leads are ALSO posted there
# (Make, Zapier, a CRM). Leave empty and the step is skipped. Server-side only,
# never shipped to the browser. No code change needed to add or remove these.
MAKE_ANALYSE_WEBHOOK=
MAKE_GUIDE_WEBHOOK=

# --- Analytics ---------------------------------------------------------------
# PostHog (EU, cookieless), reverse-proxied via /ph. PUBLIC_ is exposed to the
# client on purpose; a PostHog project key is not a secret.
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
