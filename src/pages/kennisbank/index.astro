---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import '../../styles/sections.css';

export const prerender = true;

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<SiteLayout
  title="Kennisbank, instructies over Meta Ads en SEO | Meer Impact"
  description="How-to's en instructies over Meta Ads, de Meta Pixel en SEO. Leer het zelf, of laat het ons doen. Doorzoekbaar."
>
  <Navbar />
  <main>
    <section class="mi-section mi-wrap">
      <nav aria-label="Kruimelpad"><ol class="mi-breadcrumb"><li><a href="/">Home</a></li><li>Kennisbank</li></ol></nav>
      <div class="sec-head" style="max-width:640px;margin:1.5rem 0 2rem">
        <span class="mi-overline">Kennisbank</span>
        <h1 class="mi-display" style="font-size:var(--fs-h1);margin-top:.5rem">Leer het zelf, of laat het ons doen</h1>
        <p class="mi-lede" style="margin-top:.6rem">Instructies en strategie over Meta Ads en SEO. Zoek op onderwerp.</p>
      </div>

      <div class="mi-search" style="max-width:460px;margin-bottom:2.5rem">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <input type="search" id="kb-search" placeholder="Zoek in de kennisbank, bijv. Meta Pixel" aria-label="Zoek in de kennisbank" autocomplete="off" />
      </div>

      <div class="mi-cardgrid" id="kb-grid" data-stagger>
        {posts.map((p) => (
          <a
            class="mi-card mi-mediacard mi-lift mi-glow mi-reveal mi-arrowp kb-item"
            href={`/kennisbank/${p.id}`}
            style="text-decoration:none"
            data-search={`${p.data.title} ${p.data.description} ${p.data.category}`.toLowerCase()}
          >
            <div class="mi-mediacard__img mi-ph"></div>
            <div class="mi-mediacard__body">
              <span class="mi-tag mi-tag--blue" style="align-self:flex-start">{p.data.category}</span>
              <h2 class="mi-h3" style="font-size:1.1rem">{p.data.title}</h2>
              <p class="mi-muted" style="font-size:var(--fs-body-s)">{p.data.description}</p>
              <div class="mi-mediacard__foot"><span class="av"></span><span>{p.data.author} · {fmt(p.data.publishDate)}</span><span class="mi-arrow" style="margin-left:auto;color:var(--mi-orange)">→</span></div>
            </div>
          </a>
        ))}
      </div>
      <p id="kb-empty" class="mi-empty" style="display:none">Geen artikelen gevonden. Probeer een ander woord.</p>
    </section>
  </main>
  <Footer />

  <script>
    const input = document.getElementById('kb-search');
    const items = [...document.querySelectorAll('.kb-item')];
    const empty = document.getElementById('kb-empty');
    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      items.forEach((el) => {
        const hit = !q || (el.dataset.search || '').includes(q);
        el.style.display = hit ? '' : 'none';
        if (hit) shown++;
      });
      if (empty) empty.style.display = shown === 0 ? '' : 'none';
    });
  </script>
</SiteLayout>
