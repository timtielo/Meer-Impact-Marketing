---
import SiteLayout from '../layouts/SiteLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import ReviewSource from '../components/ui/ReviewSource.astro';
import '../styles/sections.css';

const bandStats = [
  { n: '3,8×', l: 'gem. ROAS op Meta Ads', accent: true },
  { n: '+124', l: 'leads per maand' },
  { n: '40+', l: 'ondernemers geholpen' },
  { n: '€3,20', l: 'gem. kosten per lead' },
];
const cases = [
  { seg: 'Personal training', metric: '+312% leads', title: 'PT Studio Amsterdam', out: 'Van 12 naar 50 aanvragen per maand.', svc: 'Meta Ads' },
  { seg: 'Fitness', metric: '4,1× ROAS', title: 'Sportschool Utrecht', out: 'Top-3 in Google op "sportschool Utrecht".', svc: 'SEO' },
  { seg: 'Online coaching', metric: '€0,90 CPL', title: 'Coach Rotterdam', out: 'Kosten per lead gehalveerd in 6 weken.', svc: 'Meta Ads' },
];
const articles = [
  { tag: 'Instructie', title: 'Zo zet je de Meta Pixel in 10 minuten goed op', min: '6 min' },
  { tag: 'Strategie', title: 'Welk advertentiebudget heb je nodig als PT?', min: '4 min' },
  { tag: 'SEO', title: 'Lokaal vindbaar worden als sportschool', min: '7 min' },
];
const plans = [
  { name: 'Starter', price: '€495', who: 'Net begonnen met adverteren', feats: ['1 platform (Meta óf Google)', 'Campagne-opzet + pixel', 'Maandelijkse rapportage'], hot: false },
  { name: 'Groei', price: '€895', who: 'Klaar om op te schalen', feats: ['Meta + Google', 'Wekelijkse optimalisatie', 'Landingspagina inbegrepen', 'Meekijksessies'], hot: true },
  { name: 'Schaal', price: 'Op maat', who: 'Meerdere locaties / merken', feats: ['Alles uit Groei', 'Eigen strateeg', 'Creatives + copy', 'Wekelijks overleg'], hot: false },
];
---
<SiteLayout title="Blokken, Ad Manager | Meer Impact" noindex>
  <Navbar />

  <!-- HERO -->
  <header class="mi-hero">
    <div class="mi-hero__glow"></div>
    <div class="mi-wrap mi-hero__grid">
      <div>
        <span class="mi-badge"><i class="mi-dot"></i> <span class="mi-live" style="color:inherit">Meta Ads · live campagnes</span></span>
        <h1 class="mi-display">Adverteren dat je <span class="hl">terugziet in je agenda</span>.</h1>
        <p class="mi-hero__sub">Wij bouwen en sturen je Meta Ads &amp; SEO op één cijfer: leads die klant worden. Voor personal trainers, sportscholen en coaches.</p>
        <div class="mi-hero__cta">
          <a href="#analyse" class="mi-btn mi-btn--primary mi-btn--lg mi-arrowp">Vraag gratis analyse aan <span class="mi-arrow">→</span></a>
          <a href="#cases" class="mi-btn mi-btn--ghost mi-btn--lg">Bekijk cases</a>
        </div>
        <div class="mi-hero__trust">
          <div class="mi-avatars"><span></span><span></span><span></span><span></span></div>
          <ReviewSource source="google" rating="4,9" />
          <span>· 40+ ondernemers</span>
        </div>
      </div>

      <div class="mi-panel mi-reveal">
        <div class="mi-panel__bar">
          <span class="mi-tl mi-tl--r"></span><span class="mi-tl mi-tl--y"></span><span class="mi-tl mi-tl--g"></span>
          <span class="mi-panel__title">Campagne · Personal Trainers NL</span>
          <span class="mi-panel__live"><span class="mi-live">live</span></span>
        </div>
        <div class="mi-panel__body">
          <div class="mi-kpis">
            <div class="mi-stat"><div class="mi-stat__label"><span>Besteed</span></div><div class="mi-stat__value" style="font-size:1.4rem" data-count>€1.240</div></div>
            <div class="mi-stat"><div class="mi-stat__label"><span>Leads</span></div><div class="mi-stat__value" style="font-size:1.4rem" data-count>73</div></div>
            <div class="mi-stat mi-stat--hot"><div class="mi-stat__label"><span>ROAS</span></div><div class="mi-stat__value" style="font-size:1.4rem" data-count>4,2×</div></div>
          </div>
          <div class="mi-chart">
            <div class="mi-chart__cap"><span>Leads · laatste 30 dagen</span><span class="mi-delta mi-delta--up">▲ 61%</span></div>
            <svg class="mi-spark" viewBox="0 0 320 90" preserveAspectRatio="none">
              <defs><linearGradient id="heroFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0" stop-color="#f2600c" stop-opacity="0.28"/><stop offset="1" stop-color="#f2600c" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,78 L46,72 L92,74 L138,58 L184,48 L230,32 L276,20 L320,8 L320,90 L0,90 Z" fill="url(#heroFill)"/>
              <path class="line" d="M0,78 L46,72 L92,74 L138,58 L184,48 L230,32 L276,20 L320,8" fill="none" stroke="#f2600c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="sg-row" style="display:flex;flex-wrap:wrap;gap:.4rem;align-items:center"><span class="mi-mono" style="color:var(--mi-faint)">DOELGROEP</span><span class="mi-pill">Personal trainers</span><span class="mi-pill">25 km</span></div>
        </div>
      </div>
    </div>
  </header>

  <!-- LOGO STRIP -->
  <section class="mi-section" style="padding-block:var(--sp-6)">
    <p class="mi-logos__label">Vertrouwd door 40+ trainers, coaches &amp; sportscholen</p>
    <div class="mi-marquee">
      <div class="mi-marquee__track">
        {['FitLab', 'CrossPoint', 'PowerHouse', 'Studio Kracht', 'De Fitcoach', 'BodyLine', 'FitLab', 'CrossPoint', 'PowerHouse', 'Studio Kracht', 'De Fitcoach', 'BodyLine'].map((n) => <span class="mi-logo">{n}</span>)}
      </div>
    </div>
  </section>

  <!-- STAT BAND -->
  <section class="mi-statband">
    <div class="mi-wrap"><div class="mi-statband__grid">
      {bandStats.map((s) => (
        <div class="mi-statband__item">
          <div class:list={['mi-statband__num', { accent: s.accent }]} data-count>{s.n}</div>
          <div class="mi-statband__lab">{s.l}</div>
        </div>
      ))}
    </div></div>
  </section>

  <!-- BENTO -->
  <section class="mi-section mi-wrap">
    <span class="mi-overline">Wat we doen</span>
    <h2 class="mi-h2" style="margin:.5rem 0 var(--sp-5)">Eén team, elk kanaal dat groei oplevert</h2>
    <div class="mi-bento" data-stagger>
      <div class="col-4 row-2 mi-reveal mi-lift mi-glow">
        <span class="mi-tag">Hoofddienst</span>
        <h3 class="mi-h3" style="margin:.5rem 0">Meta Ads-motor</h3>
        <p class="mi-muted" style="font-size:var(--fs-body-s);max-width:40ch">Facebook &amp; Instagram advertenties, dagelijks bijgestuurd op leads. Inclusief pixel-setup en creatives.</p>
        <div class="mi-chart" style="margin-top:var(--sp-4)">
          <div class="mi-chart__cap"><span>Leads / week</span><span class="mi-delta mi-delta--up">▲ 61%</span></div>
          <svg class="mi-spark" viewBox="0 0 320 70" preserveAspectRatio="none"><path class="line" d="M0,60 L60,52 L120,54 L180,36 L240,24 L320,8" fill="none" stroke="#2563eb" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>
      <div class="col-2 mi-reveal mi-lift mi-glow"><div class="mi-stat__label"><span>Gem. CTR</span></div><div class="mi-stat__value" data-count>3,4%</div></div>
      <div class="col-2 mi-reveal mi-lift mi-glow"><div class="mi-stat__label"><span>ROAS</span><span class="mi-delta mi-delta--up">▲ 0,6</span></div><div class="mi-stat__value" style="color:var(--mi-orange)" data-count>4,2×</div></div>
      <div class="col-2 mi-reveal mi-lift mi-glow">
        <span class="mi-tag mi-tag--blue">Targeting</span>
        <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.6rem"><span class="mi-pill">Vrouwen 25-44</span><span class="mi-pill">15 km</span><span class="mi-pill">Fitness</span></div>
      </div>
      <div class="col-3 mi-reveal mi-lift mi-glow"><span class="mi-tag mi-tag--ink">Done-with-you</span><h3 class="mi-h3" style="margin-top:.5rem;font-size:1.2rem">Meekijksessie</h3><p class="mi-muted" style="font-size:var(--fs-body-s)">Live meekijken terwijl jij zelf de knoppen leert.</p></div>
      <div class="col-3 mi-reveal mi-lift mi-glow"><span class="mi-tag">Groei</span><h3 class="mi-h3" style="margin-top:.5rem;font-size:1.2rem">SEO &amp; kennisbank</h3><p class="mi-muted" style="font-size:var(--fs-body-s)">Beter vindbaar in Google, doorzoekbare how-to's.</p></div>
    </div>
  </section>

  <!-- FEATURED CASE -->
  <section class="mi-section mi-wrap" id="cases">
    <span class="mi-overline">Uitgelichte case</span>
    <h2 class="mi-h2" style="margin:.5rem 0 var(--sp-5)">Resultaten die tellen</h2>
    <div class="mi-casefeat mi-reveal">
      <div class="mi-casefeat__banner">
        <div class="mi-casefeat__kpi"><div class="n accent" data-count>+312%</div><div class="l">leads</div></div>
        <div class="mi-casefeat__kpi"><div class="n" data-count>€3,20</div><div class="l">kosten per lead</div></div>
        <div class="mi-casefeat__kpi"><div class="n" data-count>4,1×</div><div class="l">ROAS</div></div>
        <div class="mi-casefeat__kpi"><div class="n" data-count>90</div><div class="l">dagen</div></div>
      </div>
      <div class="mi-casefeat__body">
        <div class="mi-casefeat__meta">
          <strong>PT Studio Amsterdam</strong>
          <span class="mi-tag mi-tag--ink">Personal trainer</span><span class="mi-tag mi-tag--blue">Amsterdam</span><span class="mi-tag">Meta Ads</span>
        </div>
        <p class="mi-muted" style="max-width:60ch">Een drukke studio met een stille agenda buiten piekuren. We bouwden een always-on Meta-campagne op proeflessen, met wekelijkse creatives en een strakke landingspagina.</p>
        <div class="mi-beforeafter">
          <div class="mi-beforeafter__side before"><div class="mi-beforeafter__tag">Voor</div><div class="mi-beforeafter__val">12 / mnd</div><p class="mi-muted" style="font-size:var(--fs-body-s);margin-top:.3rem">aanvragen, onvoorspelbaar</p></div>
          <div class="mi-beforeafter__arrow">→</div>
          <div class="mi-beforeafter__side after"><div class="mi-beforeafter__tag">Na</div><div class="mi-beforeafter__val">50 / mnd</div><p class="mi-muted" style="font-size:var(--fs-body-s);margin-top:.3rem">aanvragen, elke week</p></div>
        </div>
        <blockquote class="mi-casefeat__quote">Eindelijk marketing die gewoon leads oplevert, en ik snap nu zelf wat er gebeurt.</blockquote>
        <div class="mi-casefeat__byline"><span class="av"></span><div><b style="color:var(--mi-ink)">Mark de Vries</b> · eigenaar PT Studio Amsterdam</div><span style="margin-left:auto"><ReviewSource source="google" rating="5,0" /></span></div>
      </div>
    </div>
  </section>

  <!-- CASE GRID -->
  <section class="mi-section mi-wrap">
    <div style="display:flex;justify-content:space-between;align-items:end;flex-wrap:wrap;gap:1rem;margin-bottom:var(--sp-5)">
      <div><span class="mi-overline">Meer succesverhalen</span><h2 class="mi-h2" style="margin-top:.5rem">Elke case linkt naar de dienst</h2></div>
      <div class="mi-filter"><button aria-pressed="true">Alle</button><button>PT</button><button>Sportschool</button><button>Coach</button></div>
    </div>
    <div class="mi-cardgrid" data-stagger>
      {cases.map((c) => (
        <article class="mi-card mi-mediacard mi-lift mi-glow mi-zoom mi-reveal mi-arrowp">
          <div class="mi-mediacard__img mi-ph">resultaat-foto</div>
          <div class="mi-mediacard__body">
            <div style="display:flex;gap:.4rem;align-items:center"><span class="mi-tag mi-tag--ink">{c.seg}</span></div>
            <div class="mi-mediacard__metric">{c.metric}</div>
            <h3>{c.title}</h3>
            <p class="mi-muted" style="font-size:var(--fs-body-s)">{c.out}</p>
            <div class="mi-mediacard__foot"><span>Dienst: {c.svc}</span><span class="mi-arrow" style="margin-left:auto;color:var(--mi-orange)">→</span></div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="mi-section mi-wrap">
    <div class="mi-testifeat mi-reveal" style="margin-bottom:var(--sp-6)">
      <span class="mi-overline">Wat klanten zeggen</span>
      <blockquote style="margin-top:var(--sp-4)">"Sinds Meer Impact onze ads doet, komt er elke week een nieuwe aanmelding binnen. En de kosten per lead? <span style="color:var(--mi-orange)">gehalveerd</span>."</blockquote>
      <div class="mi-quote__by" style="justify-content:center;margin-top:var(--sp-5)"><span class="av"></span><div style="text-align:left"><b>Lisa Bergsma</b><span>eigenaar Studio Kracht</span></div></div>
      <div style="margin-top:.85rem"><ReviewSource source="google" rating="5,0" /></div>
    </div>
    <div class="mi-testiwall" data-stagger>
      <div class="mi-card mi-quote mi-quote--anchor mi-reveal"><p>"Van 12 naar 50 proeflessen per maand. Ik hoef zelf niks meer te bedenken."</p><div class="mi-quote__by"><span class="av"></span><div><b>Mark de Vries</b><span>PT Studio Amsterdam</span></div><ReviewSource source="google" rating="5,0" /></div></div>
      <div class="mi-card mi-quote mi-reveal"><p>"Eindelijk snap ik wat mijn advertenties doen. De meekijksessies zijn goud waard."</p><div class="mi-quote__by"><span class="av"></span><div><b>Sanne Willems</b><span>Coach Rotterdam</span></div><ReviewSource source="werkspot" rating="4,9" /></div></div>
      <div class="mi-card mi-quote mi-reveal"><p>"We staan nu bovenaan in Google voor onze stad. Elke week nieuwe leden."</p><div class="mi-quote__by"><span class="av"></span><div><b>Tom Jansen</b><span>Sportschool Utrecht</span></div><ReviewSource source="google" rating="5,0" /></div></div>
      <div class="mi-card mi-quote mi-reveal"><p>"Duidelijke rapportage, korte lijnen, echte groei. Precies wat ik zocht."</p><div class="mi-quote__by"><span class="av"></span><div><b>Nadia el Amrani</b><span>FitLab</span></div><ReviewSource source="google" rating="5,0" /></div></div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="mi-section mi-wrap">
    <span class="mi-overline">Kennisbank</span>
    <h2 class="mi-h2" style="margin:.5rem 0 var(--sp-5)">Leer het zelf, of laat het ons doen</h2>
    <div class="mi-blogfeat mi-reveal mi-zoom mi-arrowp" style="margin-bottom:var(--sp-4)">
      <div class="mi-blogfeat__img mi-ph">uitgelicht artikel</div>
      <div class="mi-blogfeat__body">
        <span class="mi-tag mi-tag--blue">Uitgelicht</span>
        <h3>De complete Meta Ads-funnel voor personal trainers</h3>
        <p class="mi-muted">Van eerste advertentie tot betalende klant, het hele plan, met budgetten en voorbeelden.</p>
        <div class="mi-mediacard__foot"><span class="av"></span><span>Lars · 9 min lezen</span><span class="mi-arrow" style="margin-left:auto;color:var(--mi-orange)">Lees verder →</span></div>
      </div>
    </div>
    <div class="mi-cardgrid" data-stagger>
      {articles.map((a) => (
        <article class="mi-card mi-mediacard mi-lift mi-glow mi-zoom mi-reveal mi-arrowp">
          <div class="mi-mediacard__img mi-ph"></div>
          <div class="mi-mediacard__body">
            <span class="mi-tag mi-tag--blue" style="align-self:flex-start">{a.tag}</span>
            <h3>{a.title}</h3>
            <div class="mi-mediacard__foot"><span class="av"></span><span>Lars · {a.min}</span><span class="mi-arrow" style="margin-left:auto;color:var(--mi-orange)">→</span></div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- PRICING -->
  <section class="mi-section mi-wrap">
    <div style="text-align:center;margin-bottom:var(--sp-5)">
      <span class="mi-overline">Prijzen</span>
      <h2 class="mi-h2" style="margin:.5rem 0">Resultaatgericht, geen setup-kosten</h2>
      <div class="mi-toggle" style="margin-top:var(--sp-4)"><button aria-pressed="true">Maandelijks</button><button>Kwartaal <span class="mi-tag" style="margin-left:.3rem">-15%</span></button></div>
    </div>
    <div class="mi-plans" data-stagger>
      {plans.map((p) => (
        <div class:list={['mi-card', 'mi-plan', 'mi-reveal', { 'mi-plan--hot': p.hot }]}>
          {p.hot && <span class="mi-plan__badge">Meest gekozen</span>}
          <div class="mi-plan__name">{p.name}</div>
          <div class="mi-plan__price">{p.price}<span>{p.price.startsWith('€') ? ' /maand' : ''}</span></div>
          <p class="mi-muted" style="font-size:var(--fs-body-s)">{p.who}</p>
          <ul class="mi-plan__list">{p.feats.map((f) => <li>{f}</li>)}</ul>
          <a href="#analyse" class:list={['mi-btn', p.hot ? 'mi-btn--primary' : 'mi-btn--ghost']} style="margin-top:auto">Start met {p.name}</a>
        </div>
      ))}
    </div>
    <p class="mi-muted" style="text-align:center;font-size:var(--fs-caption);margin-top:var(--sp-4)">Advertentiebudget betaal je apart, rechtstreeks aan het platform. Maandelijks opzegbaar.</p>
  </section>

  <!-- CTA -->
  <section class="mi-section mi-wrap" id="analyse">
    <div class="mi-cta mi-reveal">
      <div class="mi-cta__glow"></div>
      <div class="mi-cta__float mi-cta__float--l"><div class="n" data-count>+312%</div><div class="l">leads</div></div>
      <div class="mi-cta__float mi-cta__float--r"><div class="n" data-count>4,2×</div><div class="l">ROAS</div></div>
      <div class="mi-cta__inner">
        <h2>Klaar voor meer klanten uit Meta &amp; Google?</h2>
        <p>Vraag een gratis marketinganalyse aan. Geen verplichtingen, wel een concreet plan binnen 1 werkdag.</p>
        <a href="#" class="mi-btn mi-btn--primary mi-btn--lg mi-magnetic mi-arrowp">Vraag gratis analyse aan <span class="mi-arrow">→</span></a>
      </div>
    </div>
  </section>

  <Footer />
</SiteLayout>
