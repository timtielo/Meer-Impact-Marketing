---
import DesignLayout from '../../layouts/DesignLayout.astro';
import HeroAdManager from '../../components/design/heroes/HeroAdManager.astro';
import Sections from '../../components/design/Sections.astro';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/instrument-sans';
---
<DesignLayout title="Richting 1 — Ad Manager | Meer Impact" active={1}>
  <div data-dir="admanager">
    <HeroAdManager />
    <Sections
      id={1}
      name="Ad Manager"
      signature="De hero ís een live Meta Ads-dashboard — campagne, stijgende ROAS-grafiek, doelgroep-targeting."
      tagline="Performance-marketing look: voelt als de tool die Lars beheerst. Dashboard-esthetiek, tabulaire cijfers, strak en zakelijk. Vertrouwen via data."
      fontNote="Space Grotesk (display) + Instrument Sans (body)"
      palette={[
        { hex: '#f2600c', label: 'Oranje (primair)' },
        { hex: '#0b1f3a', label: 'Diep navy' },
        { hex: '#2563eb', label: 'Chart-blauw' },
        { hex: '#eef1f6', label: 'Canvas' },
        { hex: '#ffffff', label: 'Panel' },
      ]}
    />
  </div>
</DesignLayout>
