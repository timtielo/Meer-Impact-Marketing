---
import DesignLayout from '../../layouts/DesignLayout.astro';
import HeroVoorNa from '../../components/design/heroes/HeroVoorNa.astro';
import Sections from '../../components/design/Sections.astro';
import '@fontsource-variable/archivo';
import '@fontsource-variable/instrument-sans';
---
<DesignLayout title="Richting 2 — Voor / Na | Meer Impact" active={2}>
  <div data-dir="voorna">
    <HeroVoorNa />
    <Sections
      id={2}
      name="Voor / Na"
      signature="Een harde VOOR/NA-split — grijs & vlak versus kleurrijk & stijgend. De transformatie zelf."
      tagline="De personal-trainer before/after, vertaald naar bedrijfsresultaat. Contrastrijk, verhalend, meteen te snappen."
      fontNote="Archivo (display, expanded/black) + Instrument Sans"
      palette={[
        { hex: '#ea580c', label: 'Oranje (na)' },
        { hex: '#12224e', label: 'Navy' },
        { hex: '#e5e7eb', label: 'Voor-grijs' },
        { hex: '#f6f7f9', label: 'Vlak' },
        { hex: '#0f172a', label: 'Inkt' },
      ]}
    />
  </div>
</DesignLayout>
