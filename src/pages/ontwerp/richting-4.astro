---
import DesignLayout from '../../layouts/DesignLayout.astro';
import HeroCoach from '../../components/design/heroes/HeroCoach.astro';
import Sections from '../../components/design/Sections.astro';
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/instrument-sans';
---
<DesignLayout title="Richting 4 — Coach | Meer Impact" active={4}>
  <div data-dir="coach">
    <HeroCoach />
    <Sections
      id={4}
      name="Coach / Direct"
      signature="Color-block editorial met een confronterende coach-vraag — direct en menselijk."
      tagline="No-nonsense, spreekt je persoonlijk aan. Oranje/navy kleurblokken, karaktervolle display, scherpe hoeken. Persoonlijk maar stevig."
      fontNote="Bricolage Grotesque (display) + Instrument Sans"
      palette={[
        { hex: '#ea580c', label: 'Oranje' },
        { hex: '#101a3a', label: 'Navy' },
        { hex: '#fbfaf7', label: 'Off-white' },
        { hex: '#12131a', label: 'Inkt' },
        { hex: '#f3efe7', label: 'Vlak' },
      ]}
    />
  </div>
</DesignLayout>
