    palette={[
      { hex: '#e2661f', label: 'Warm oranje' },
      { hex: '#24405e', label: 'Gedempt blauw' },
      { hex: '#fffaf3', label: 'Crème (basis)' },
      { hex: '#fdf1e7', label: 'Perzik' },
      { hex: '#2b2118', label: 'Warm inkt' },
    ]}
  />
