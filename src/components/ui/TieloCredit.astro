---
/**
 * Tielo credit — the "Website door Tielo Digital" footer stamp.
 *
 * Goes on EVERY client site. Two jobs at once:
 *   1. A subtle, tasteful credit in/under the footer.
 *   2. A real dofollow backlink to tielo-digital.nl — the single biggest
 *      backlink asset for Tielo's own local SEO (see the marketing area's
 *      eigen-site-backlinks-nap.md). So: plain <a>, NO rel="nofollow".
 *
 * The icon is the REAL Tielo Digital mark (the TD monogram, td-transp.png),
 * embedded as a CSS mask: the mask gives the shape, `background-color` gives
 * the colour. The whole stamp is MONOCHROME and inherits `currentColor`, so it
 * is black on a light footer, white on a dark one, mid on anything between —
 * transparent, no chip, reads on any background. Override with `ink` if you
 * ever need to force a colour.
 *
 * DELIBERATELY NOT client-themeable in the brand-* sense — it's the fixed Tielo
 * stamp. Anchor text is the brand name "Tielo Digital" (not a keyword phrase).
 *
 * Props:
 *   variant  'badge' | 'bar' | 'inline'   default 'badge'
 *              badge  — ghost outline pill for a footer CORNER (recommended).
 *              bar    — full-width centered strip, hairline top border, the
 *                       sub-footer line UNDER the main footer.
 *              inline — just the link; drop it anywhere.
 *   prefix   string   caption lead-in, default 'Website door'
 *   href     string   default 'https://www.tielo-digital.nl'
 *   newTab   boolean  open in a new tab, default true
 *   ink      string   optional fixed colour (any CSS colour); default = inherit
 *                      the footer's currentColor (auto black/white/between).
 *                      CONTRAST CAVEAT: if the footer container's default text
 *                      colour is dark (light set per-element, not on the
 *                      container), the badge inherits dark-on-dark and can
 *                      disappear — pass an explicit readable `ink` then.
 *   class    string   extra classes on the root (positioning, etc.)
 */
interface Props {
  variant?: 'badge' | 'bar' | 'inline'
  prefix?: string
  href?: string
  newTab?: boolean
  ink?: string
  class?: string
}
const {
  variant = 'badge',
  prefix = 'Website door',
  href = 'https://www.tielo-digital.nl',
  newTab = true,
  ink,
  class: extra = '',
} = Astro.props

const target = newTab ? '_blank' : undefined
const rel = newTab ? 'noopener' : undefined
const style = ink ? `color:${ink}` : undefined
---

{variant === 'bar' ? (
  <div class:list={['tielo-credit-bar', extra]} style={style}>
    <a class="tielo-credit" href={href} target={target} rel={rel}>
      <span class="tielo-mark" aria-hidden="true" />
      <span class="tielo-credit__text">{prefix} <strong>Tielo Digital</strong></span>
    </a>
  </div>
) : (
  <a
    class:list={['tielo-credit', variant === 'badge' && 'tielo-credit--badge', extra]}
    style={style}
    href={href}
    target={target}
    rel={rel}
  >
    <span class="tielo-mark" aria-hidden="true" />
    <span class="tielo-credit__text">{prefix} <strong>Tielo Digital</strong></span>
  </a>
)}

<style>
  /* Monochrome, inherits currentColor. Transparent — reads on any background. */
  .tielo-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.8125rem; /* 13px */
    line-height: 1;
    color: currentColor;
    text-decoration: none;
    transition: opacity 0.15s ease, background-color 0.15s ease;
  }
  .tielo-credit:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
    border-radius: 999px;
  }
  .tielo-credit__text { white-space: nowrap; }
  .tielo-credit__text strong { font-weight: 600; }
  .tielo-credit:hover .tielo-credit__text strong { text-decoration: underline; text-underline-offset: 2px; }

  /* The real TD mark: mask = shape, currentColor = colour. */
  .tielo-mark {
    display: block;
    flex: none;
    height: 1.2em;
    aspect-ratio: 104 / 66;
    background-color: currentColor;
    --td: url("data:image/png;base64,");
    -webkit-mask: var(--td) center / contain no-repeat;
    mask: var(--td) center / contain no-repeat;
  }

  /* bar + inline read as a quiet credit (muted); badge is a full-strength stamp */
  .tielo-credit:not(.tielo-credit--badge) { opacity: 0.6; }
  .tielo-credit:not(.tielo-credit--badge):hover,
  .tielo-credit:focus-visible { opacity: 1; }

  /* variant: badge — ghost outline pill for a footer corner */
  .tielo-credit--badge {
    padding: 0.4rem 0.82rem 0.4rem 0.72rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 26%, transparent);
    background: transparent;
  }
  .tielo-credit--badge:hover { background: color-mix(in srgb, currentColor 7%, transparent); }

  /* variant: bar — centered sub-footer strip */
  .tielo-credit-bar {
    display: flex;
    justify-content: center;
    padding: 1rem 1.25rem;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .tielo-credit { transition: none; }
  }
</style>
