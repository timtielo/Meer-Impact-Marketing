---
// Site footer: newsletter, link columns, oversized wordmark, dynamic year.
import TieloCredit from './TieloCredit.astro';
const year = new Date().getFullYear();
const cols = [
  { h: 'Diensten', links: ['Meta Ads', 'Meekijksessie', 'SEO', 'Email Marketing'] },
  { h: 'Bedrijf', links: ['Cases', 'Over ons', 'Contact', 'Werken bij'] },
  { h: 'Kennisbank', links: ['Alle artikelen', 'Meta Pixel', 'SEO voor PTs', 'Gratis guide'] },
];
---
<footer class="mi-sitefooter">
  <div class="mi-wrap">
    <div class="mi-sitefooter__news">
      <div>
        <h3>Marketing-tips voor trainers &amp; sportscholen</h3>
        <p style="color:rgba(255,255,255,0.7);margin-top:.4rem">Eén mail per maand. Concrete tactieken, geen ruis.</p>
      </div>
      <form class="mi-sitefooter__form" onsubmit="return false">
        <input type="email" placeholder="jij@bedrijf.nl" aria-label="E-mailadres" />
        <button class="mi-btn mi-btn--primary" type="submit">Inschrijven</button>
      </form>
    </div>

    <div class="mi-sitefooter__cols">
      <div class="mi-sitefooter__col">
        <img src="/logo-horizontal-white.png" alt="Meer Impact Marketing" width="160" height="36" style="height:34px;width:auto" />
        <p style="margin-top:.75rem;font-size:.9rem;max-width:32ch">Meta Ads &amp; SEO die groei opleveren. Specialist in de fitnessbranche.</p>
      </div>
      {cols.map((c) => (
        <div class="mi-sitefooter__col">
          <h4>{c.h}</h4>
          {c.links.map((l) => <a href="#">{l}</a>)}
        </div>
      ))}
    </div>

    <div class="mi-sitefooter__word" aria-hidden="true">MEER IMPACT</div>

    <div class="mi-sitefooter__bottom">
      <span>© {year} Meer Impact Marketing · KvK 00000000</span>
      <span class="mi-live" style="color:#7ee2a8">Beschikbaar voor nieuwe klanten</span>
      <TieloCredit variant="inline" />
    </div>
  </div>
</footer>
