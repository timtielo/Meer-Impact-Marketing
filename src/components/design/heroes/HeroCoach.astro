---
// Signature: color-block editorial + a confrontational, coach-style question.
// Direct voice, offset blocks, duotone image stand-in. Feels like a no-nonsense
// coach talking straight to you.
import './HeroCoach.css';
---
<header class="co-head">
  <div class="wrap co-head-in">
    <img src="/logo-horizontal.svg" alt="Meer Impact Marketing" class="co-logo" onerror="this.onerror=null;this.src='/Meer%20Impact%20Marketing%20logo%20horizontal.png'" />
    <nav class="co-nav">
      <a href="#">Diensten</a><a href="#">Cases</a><a href="#">Kennisbank</a>
      <a href="#" class="btn btn-primary btn-sm">Gratis analyse</a>
    </nav>
  </div>
</header>

<section class="co-hero">
  <div class="wrap co-grid">
    <div class="co-copy">
      <span class="co-eyebrow">Meta Ads &amp; SEO · fitnessbranche</span>
      <h1>Waarom groeit je <span class="mark">concurrent</span> wél online?</h1>
      <p class="co-lede">Negen van de tien personal trainers verbranden hun advertentiebudget zonder plan. Wij draaien het om: elke euro meetbaar, elke week nieuwe aanvragen. Gegarandeerd.</p>
      <div class="co-cta">
        <a href="#" class="btn btn-primary btn-lg">Claim je gratis analyse →</a>
        <a href="#" class="btn btn-ghost btn-lg">Bekijk cases</a>
      </div>
    </div>

    <div class="co-blocks" aria-hidden="true">
      <div class="blk blk-photo"><span class="blk-cap">[ jouw studio, druk ]</span></div>
      <div class="blk blk-orange">
        <span class="blk-num">4,2×</span>
        <span class="blk-lab">ROAS bij PT Studio Amsterdam</span>
      </div>
      <div class="blk blk-navy">
        <span class="blk-q">"Eindelijk marketing die gewoon leads oplevert."</span>
      </div>
    </div>
  </div>
</section>

