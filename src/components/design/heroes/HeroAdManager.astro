---
// Signature: the hero IS a live-looking Meta Ads Manager panel. Leads with the
// tool Lars masters instead of a headline+stat template.
import './HeroAdManager.css';
---
<header class="am-head">
  <div class="wrap am-head-in">
    <img src="/logo-horizontal.svg" alt="Meer Impact Marketing" class="am-logo" onerror="this.onerror=null;this.src='/Meer%20Impact%20Marketing%20logo%20horizontal.png'" />
    <nav class="am-nav">
      <a href="#">Diensten</a><a href="#">Cases</a><a href="#">Kennisbank</a>
      <a href="#" class="btn btn-primary btn-sm">Gratis analyse</a>
    </nav>
  </div>
</header>

<section class="am-hero">
  <div class="wrap am-grid">
    <div class="am-copy">
      <span class="badge"><i class="dot"></i> Meta Ads · Performance</span>
      <h1>Adverteren dat je<br /><span class="u">terugziet in je agenda</span>.</h1>
      <p class="am-lede">Wij bouwen en sturen je Meta Ads op één cijfer: leads die klant worden. Voor personal trainers, sportscholen en coaches.</p>
      <div class="am-cta">
        <a href="#" class="btn btn-primary btn-lg">Start jouw groei →</a>
        <a href="#" class="btn btn-ghost btn-lg">Bekijk cases</a>
      </div>
      <p class="am-trust">Gem. <strong>3,8× ROAS</strong> · geen setup-risico · maandelijks opzegbaar</p>
    </div>

    <!-- Signature dashboard -->
    <div class="dash" aria-hidden="true">
      <div class="dash-bar">
        <span class="d d1"></span><span class="d d2"></span><span class="d d3"></span>
        <span class="dash-title">Campagne · Personal Trainers NL</span>
        <span class="dash-live">● live</span>
      </div>
      <div class="dash-body">
        <div class="dash-kpis">
          <div class="kpi"><span class="kpi-l">Besteed</span><span class="kpi-v">€1.240</span></div>
          <div class="kpi"><span class="kpi-l">Leads</span><span class="kpi-v">73</span></div>
          <div class="kpi hot"><span class="kpi-l">ROAS</span><span class="kpi-v">4,2×</span></div>
        </div>
        <div class="dash-chart">
          <span class="chart-cap">Leads · laatste 30 dagen <em>▲ 61%</em></span>
          <svg viewBox="0 0 320 120" preserveAspectRatio="none">
            <defs>
              <linearGradient id="amfill" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0" stop-color="var(--brand)" stop-opacity="0.35" />
                <stop offset="1" stop-color="var(--brand)" stop-opacity="0" />
              </linearGradient>
            </defs>
            <path d="M0,105 L40,98 L80,100 L120,82 L160,70 L200,58 L240,40 L280,26 L320,12 L320,120 L0,120 Z" fill="url(#amfill)" />
            <path d="M0,105 L40,98 L80,100 L120,82 L160,70 L200,58 L240,40 L280,26 L320,12" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="dash-aud">
          <span class="aud-l">Doelgroep</span>
          <span class="pill">Personal trainers</span>
          <span class="pill">Sportscholen · 25 km</span>
          <span class="pill">25–45 jr</span>
        </div>
      </div>
    </div>
  </div>
</section>

