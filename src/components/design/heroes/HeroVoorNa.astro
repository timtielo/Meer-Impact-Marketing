---
// Signature: a hard VOOR/NA split - the personal-trainer before/after trope
// applied to business results. The transformation IS the hero.
import './HeroVoorNa.css';
---
<header class="vn-head">
  <div class="wrap vn-head-in">
    <img src="/logo-horizontal.svg" alt="Meer Impact Marketing" class="vn-logo" onerror="this.onerror=null;this.src='/Meer%20Impact%20Marketing%20logo%20horizontal.png'" />
    <nav class="vn-nav">
      <a href="#">Diensten</a><a href="#">Cases</a><a href="#">Kennisbank</a>
      <a href="#" class="btn btn-primary btn-sm">Gratis analyse</a>
    </nav>
  </div>
</header>

<section class="vn-hero">
  <div class="wrap">
    <div class="vn-copy">
      <span class="badge"><i class="dot"></i> De transformatie</span>
      <h1>Van marketing die <span class="strike">geld kost</span> naar <span class="hl">aanvraag na aanvraag</span>.</h1>
      <p class="vn-lede">Specialist in Meta Ads en SEO voor de fitnessbranche. Zelfde bedrijf, ander resultaat.</p>
    </div>

    <div class="split" aria-hidden="true">
      <div class="pane voor">
        <span class="pane-tag">VOOR</span>
        <span class="pane-metric">Geld eruit</span>
        <span class="pane-sub">niks terug</span>
        <div class="spark spark-flat"></div>
        <ul>
          <li>Advertenties zonder plan</li>
          <li>Geen idee wat werkt</li>
          <li>Stille telefoon</li>
        </ul>
      </div>
      <div class="handle"><span>&rarr;</span></div>
      <div class="pane na">
        <span class="pane-tag">NA</span>
        <span class="pane-metric">4,2&times; ROAS</span>
        <span class="pane-sub">+38 klanten in 3 mnd</span>
        <div class="spark spark-rise"></div>
        <ul>
          <li>Advertenties met strategie</li>
          <li>Meetbaar op elke euro</li>
          <li>Wekelijks nieuwe leads</li>
        </ul>
      </div>
    </div>

    <div class="vn-cta">
      <a href="#" class="btn btn-primary btn-lg">Start jouw transformatie &rarr;</a>
      <a href="#" class="btn btn-ghost btn-lg">Bekijk cases</a>
    </div>
  </div>
</section>

