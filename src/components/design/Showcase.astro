---
// Shared styleguide showcase. Identical content across all 4 directions so the
// comparison is apples-to-apples; the LOOK is driven entirely by --vars +
// [data-variant] in the scoped <style> below.
interface Props {
  id: number;
  name: string;
  tagline: string;
  variant: 'energetic' | 'corporate' | 'dark' | 'warm';
  palette: { hex: string; label: string }[];
  fontNote: string;
}
const { id, name, tagline, variant, palette, fontNote } = Astro.props;

const stats = [
  { big: '3,8×', label: 'gem. ROAS op Meta Ads' },
  { big: '+124', label: 'leads per maand' },
  { big: '40+', label: 'ondernemers geholpen' },
  { big: '€0', label: 'risico — garantie' },
];

const services = [
  { name: 'Meta Ads', tag: 'Hoofddienst', desc: 'Facebook & Instagram advertenties die jouw ideale klant bereiken en meetbaar leads opleveren.', caseName: 'PT Studio Amsterdam' },
  { name: 'SEO', tag: 'Groei', desc: 'Beter vindbaar in Google op de zoekwoorden waar jouw klanten écht op zoeken.', caseName: 'Sportschool Utrecht' },
  { name: 'Email Marketing', tag: 'Retentie', desc: 'Automatische flows die leads warm houden en klanten laten terugkomen.', caseName: 'Coach Rotterdam' },
  { name: 'Copywriting', tag: 'Conversie', desc: 'Teksten die overtuigen — van advertentie tot landingspagina.', caseName: 'PT Studio Amsterdam' },
];

const cases = [
  { client: 'PT Studio Amsterdam', segment: 'Personal training', metric: '4,2× ROAS', sub: '+38 nieuwe klanten in 3 mnd', service: 'Meta Ads' },
  { client: 'Sportschool Utrecht', segment: 'Fitness', metric: '−41% kostprijs/lead', sub: 'Top-3 in Google lokaal', service: 'SEO' },
  { client: 'Coach Rotterdam', segment: 'Online coaching', metric: '32% meer omzet', sub: 'via e-mail automation', service: 'Email Marketing' },
];

const diffs = [
  { t: 'Garantie', d: 'Jij neemt niet al het risico — dat delen we. Een samenwerking moet win-win zijn.' },
  { t: 'Resultaat', d: 'Geen loze beloftes, maar meetbare groei. Focus op leads en omzet.' },
  { t: 'Persoonlijk', d: 'Korte lijnen, snelle communicatie. Geen accountmanager-carrousel.' },
  { t: 'Specialisatie', d: 'Geen allesdoeners. Experts in Meta Ads en SEO voor jouw niche.' },
];
---

<div class="stage" data-variant={variant}>
  <!-- ============ HEADER ============ -->
  <header class="site-head">
    <div class="wrap head-inner">
      <img src="/logo-horizontal.svg" alt="Meer Impact Marketing" class="logo" onerror="this.onerror=null;this.src='/Meer%20Impact%20Marketing%20logo%20horizontal.png'" />
      <nav class="head-nav">
        <a href="#">Diensten</a>
        <a href="#">Succesverhalen</a>
        <a href="#">Gratis guide</a>
        <a href="#">Blog</a>
        <a href="#" class="btn btn-primary btn-sm">Contact</a>
      </nav>
    </div>
  </header>

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="badge"><i class="dot"></i> Boost jouw online aanwezigheid</span>
        <h1>
          <span class="hl">Meer</span> Groei,<br />
          <span class="hl">Meer</span> Klanten,<br />
          <span class="hl">Meer</span> Impact.
        </h1>
        <p class="guarantee">Gegarandeerd.</p>
        <p class="lede">Specialist in <strong>Meta Ads</strong> en <strong>SEO</strong> voor personal trainers, sportscholen en coaches. Meer leads, meetbaar resultaat.</p>
        <div class="hero-cta">
          <a href="#" class="btn btn-primary">Start jouw groei →</a>
          <a href="#" class="btn btn-ghost">Bekijk resultaten</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="tile t1"><span class="tile-num">3,8×</span><span class="tile-lab">ROAS</span></div>
        <div class="tile t2"><span class="tile-num">+124</span><span class="tile-lab">leads/mnd</span></div>
        <div class="tile t3"><span class="tile-num">40+</span><span class="tile-lab">klanten</span></div>
        <div class="tile t4"><span class="tile-num">€0</span><span class="tile-lab">risico</span></div>
      </div>
    </div>
  </section>

  <!-- ============ STATS STRIP ============ -->
  <section class="stats">
    <div class="wrap stats-row">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat-big">{s.big}</span>
          <span class="stat-lab">{s.label}</span>
        </div>
      ))}
    </div>
    <p class="wrap ph-note">Voorbeeldcijfers — vervangen door echte cases bij oplevering.</p>
  </section>

  <!-- ============ SERVICES (link → case) ============ -->
  <section class="services">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Onze diensten</span>
        <h2>Waar we het verschil maken</h2>
        <p class="sec-sub">Elke dienst is gekoppeld aan een echte case, zodat je ziet wat het oplevert.</p>
      </div>
      <div class="svc-grid">
        {services.map((s) => (
          <article class="svc-card">
            <div class="svc-icon">{s.name === 'Meta Ads' ? '◈' : s.name === 'SEO' ? '⌕' : s.name === 'Email Marketing' ? '✉' : '✎'}</div>
            <div class="svc-body">
              <span class="svc-tag">{s.tag}</span>
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
              <a class="svc-link" href="#">Bekijk case: {s.caseName} →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CASES (link → service) ============ -->
  <section class="cases">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Succesverhalen</span>
        <h2>Resultaten die tellen</h2>
        <p class="sec-sub">Elke case linkt terug naar de dienst die het mogelijk maakte.</p>
      </div>
      <div class="case-grid">
        {cases.map((c) => (
          <article class="case-card">
            <div class="case-top">
              <span class="case-seg">{c.segment}</span>
              <span class="case-metric">{c.metric}</span>
            </div>
            <h3>{c.client}</h3>
            <p class="case-sub">{c.sub}</p>
            <a class="case-service" href="#">Dienst: {c.service} →</a>
          </article>
        ))}
      </div>
      <p class="ph-note">Placeholder-cases — structuur staat, echte cijfers vult Lars in.</p>
    </div>
  </section>

  <!-- ============ DIFFERENTIATORS ============ -->
  <section class="diffs">
    <div class="wrap">
      <div class="sec-head">
        <h2>"Oké, wat maakt jou anders?"</h2>
      </div>
      <div class="diff-grid">
        {diffs.map((d, i) => (
          <div class="diff-card">
            <span class="diff-num">0{i + 1}</span>
            <h3>{d.t}</h3>
            <p>{d.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIAL ============ -->
  <section class="quote">
    <div class="wrap quote-inner">
      <p class="quote-mark">“</p>
      <blockquote>Sinds Meer Impact onze Meta Ads doet, komen er elke week nieuwe aanmeldingen binnen. Eindelijk marketing die gewoon leads oplevert.</blockquote>
      <p class="quote-by">— Voorbeeldklant, Personal Trainer</p>
    </div>
  </section>

  <!-- ============ CTA BAND ============ -->
  <section class="cta-band">
    <div class="wrap cta-inner">
      <h2>Klaar voor meer klanten?</h2>
      <p>Vraag een gratis marketinganalyse aan. Geen verplichtingen — wel een concreet plan.</p>
      <a href="#" class="btn btn-primary btn-lg">Gratis analyse aanvragen →</a>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="site-foot">
    <div class="wrap foot-grid">
      <div class="foot-brand">
        <span class="foot-logo">Meer Impact Marketing</span>
        <p>Meta Ads &amp; SEO die groei opleveren.</p>
      </div>
      <div class="foot-col">
        <h4>Diensten</h4>
        <a href="#">Meta Ads</a><a href="#">SEO</a><a href="#">Email Marketing</a><a href="#">Copywriting</a>
      </div>
      <div class="foot-col">
        <h4>Bedrijf</h4>
        <a href="#">Succesverhalen</a><a href="#">Blog</a><a href="#">Contact</a><a href="#">Gratis guide</a>
      </div>
    </div>
    <div class="wrap foot-bottom">
      <span>© 2026 Meer Impact Marketing</span>
      <span class="foot-credit">Website door <strong>Tielo Digital</strong> ◆</span>
    </div>
  </footer>

  <!-- ============ STYLEGUIDE STRIP (tokens) ============ -->
  <section class="guide">
    <div class="wrap">
      <div class="guide-head">
        <span class="guide-kicker">Richting {id}</span>
        <h2 class="guide-title">{name}</h2>
        <p class="guide-tag">{tagline}</p>
      </div>

      <div class="guide-block">
        <h5>Kleuren</h5>
        <div class="swatches">
          {palette.map((p) => (
            <div class="swatch">
              <span class="sw-chip" style={`background:${p.hex}`}></span>
              <span class="sw-hex">{p.hex}</span>
              <span class="sw-lab">{p.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="guide-block">
        <h5>Typografie <span class="guide-note">{fontNote}</span></h5>
        <div class="type-spec">
          <p class="ts-h1">Meer Impact</p>
          <p class="ts-h2">Meta Ads &amp; SEO die groeien</p>
          <p class="ts-body">Bodytekst: helder, tutoyerend en resultaatgericht. Zo leest de hele site.</p>
        </div>
      </div>

      <div class="guide-block">
        <h5>Componenten</h5>
        <div class="comp-row">
          <a href="#" class="btn btn-primary">Primaire knop</a>
          <a href="#" class="btn btn-ghost">Secundaire knop</a>
          <span class="badge"><i class="dot"></i> Badge</span>
          <span class="svc-tag">Label</span>
        </div>
        <div class="comp-form">
          <input type="text" placeholder="Je naam" readonly />
          <input type="email" placeholder="Je e-mailadres" readonly />
          <a href="#" class="btn btn-primary">Verstuur</a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* ============================================================= */
  /*  BASE STRUCTURE (shared) — appearance comes from the vars      */
  /* ============================================================= */
  .stage {
    --bg: #ffffff;
    --alt: #f8fafc;
    --ink: #0f172a;
    --muted: #475569;
    --brand: #ea580c;
    --brand-2: #c2410e;
    --navy: #1e3a8a;
    --card: #ffffff;
    --card-br: #eef1f5;
    --radius: 16px;
    --btn-radius: 10px;
    --shadow: 0 14px 34px -18px rgba(15, 23, 42, 0.28);
    --head-font: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
    --head-weight: 900;
    --head-tracking: -0.03em;
    --foot-bg: #0b1120;
    --foot-ink: #cbd5e1;

    background: var(--bg);
    color: var(--ink);
    font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }
  .stage :where(h1, h2, h3, h4, h5) {
    font-family: var(--head-font);
    letter-spacing: var(--head-tracking);
    line-height: 1.08;
    margin: 0;
  }
  .wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding-inline: 1.5rem;
    width: 100%;
  }
  .stage p { margin: 0; }
  .stage a { color: inherit; }

  /* ---------- buttons ---------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.85rem 1.5rem;
    border-radius: var(--btn-radius);
    font-size: 1rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    cursor: pointer;
    border: 2px solid transparent;
    line-height: 1;
  }
  .btn-sm { padding: 0.55rem 1rem; font-size: 0.9rem; }
  .btn-lg { padding: 1.05rem 2rem; font-size: 1.1rem; }
  .btn-primary {
    background: var(--brand);
    color: #fff;
    box-shadow: 0 10px 24px -10px color-mix(in srgb, var(--brand) 65%, transparent);
  }
  .btn-primary:hover { background: var(--brand-2); transform: translateY(-2px); }
  .btn-ghost {
    background: transparent;
    color: var(--ink);
    border-color: color-mix(in srgb, var(--ink) 18%, transparent);
  }
  .btn-ghost:hover { border-color: var(--brand); color: var(--brand); }

  /* ---------- badges / tags ---------- */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    color: var(--brand-2);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
  }
  .badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--brand); display: inline-block; }
  .svc-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-2);
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand);
    margin-bottom: 0.75rem;
  }

  /* ---------- header ---------- */
  .site-head {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--card-br);
  }
  .head-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 0.9rem; }
  .logo { height: 40px; width: auto; }
  .head-nav { display: flex; align-items: center; gap: 1.5rem; }
  .head-nav a { text-decoration: none; font-weight: 600; font-size: 0.95rem; color: var(--muted); }
  .head-nav a:hover { color: var(--brand); }
  .head-nav a.btn { color: #fff; }
  @media (max-width: 780px) { .head-nav a:not(.btn) { display: none; } }

  /* ---------- hero ---------- */
  .hero { padding-block: clamp(3rem, 8vw, 6rem); position: relative; }
  .hero-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 3rem; align-items: center; }
  @media (max-width: 860px) { .hero-grid { grid-template-columns: 1fr; } }
  .hero h1 { font-size: clamp(2.6rem, 6.5vw, 4.6rem); font-weight: var(--head-weight); }
  .hero .hl { color: var(--brand); }
  .guarantee { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: var(--head-weight); color: var(--navy); font-family: var(--head-font); letter-spacing: var(--head-tracking); margin-top: 0.25rem; }
  .lede { font-size: 1.15rem; color: var(--muted); max-width: 34ch; margin-top: 1.25rem; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.75rem; }
  .badge { margin-bottom: 1.25rem; }
  .hero-visual { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .tile {
    background: var(--card);
    border: 1px solid var(--card-br);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .tile-num { font-size: 2rem; font-weight: 900; color: var(--brand); font-family: var(--head-font); }
  .tile-lab { font-size: 0.85rem; color: var(--muted); font-weight: 600; }
  .tile.t2, .tile.t3 { transform: translateY(1.25rem); }

  /* ---------- stats ---------- */
  .stats { background: var(--alt); padding-block: 2.5rem; }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  @media (max-width: 720px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
  .stat { text-align: center; }
  .stat-big { display: block; font-size: 2.4rem; font-weight: 900; color: var(--navy); font-family: var(--head-font); letter-spacing: var(--head-tracking); }
  .stat-lab { font-size: 0.9rem; color: var(--muted); }
  .ph-note { font-size: 0.78rem; color: var(--muted); opacity: 0.7; font-style: italic; margin-top: 1rem; text-align: center; }

  /* ---------- section heads ---------- */
  section { position: relative; }
  .services, .diffs { padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .cases { padding-block: clamp(3.5rem, 7vw, 5.5rem); background: var(--alt); }
  .sec-head { max-width: 620px; margin-bottom: 2.75rem; }
  .sec-head h2 { font-size: clamp(1.9rem, 4vw, 2.8rem); font-weight: var(--head-weight); }
  .sec-sub { color: var(--muted); margin-top: 0.75rem; font-size: 1.05rem; }

  /* ---------- services grid ---------- */
  .svc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  @media (max-width: 720px) { .svc-grid { grid-template-columns: 1fr; } }
  .svc-card {
    display: flex;
    gap: 1.25rem;
    background: var(--card);
    border: 1px solid var(--card-br);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .svc-card:hover { transform: translateY(-4px); }
  .svc-icon {
    flex-shrink: 0;
    width: 52px; height: 52px;
    display: grid; place-items: center;
    font-size: 1.5rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--brand) 14%, transparent);
    color: var(--brand-2);
  }
  .svc-card h3 { font-size: 1.35rem; margin-block: 0.4rem 0.5rem; }
  .svc-card p { color: var(--muted); font-size: 0.98rem; }
  .svc-link { display: inline-block; margin-top: 0.9rem; font-weight: 700; color: var(--brand); text-decoration: none; font-size: 0.92rem; }
  .svc-link:hover { text-decoration: underline; }

  /* ---------- case grid ---------- */
  .case-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 820px) { .case-grid { grid-template-columns: 1fr; } }
  .case-card {
    background: var(--card);
    border: 1px solid var(--card-br);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .case-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .case-seg { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); }
  .case-metric { font-size: 1.35rem; font-weight: 900; color: var(--brand); font-family: var(--head-font); }
  .case-card h3 { font-size: 1.25rem; margin-top: 0.5rem; }
  .case-sub { color: var(--muted); font-size: 0.95rem; }
  .case-service { margin-top: auto; padding-top: 0.9rem; font-weight: 700; color: var(--navy); text-decoration: none; font-size: 0.9rem; }
  .case-service:hover { color: var(--brand); }

  /* ---------- differentiators ---------- */
  .diff-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem 2.5rem; }
  @media (max-width: 720px) { .diff-grid { grid-template-columns: 1fr; } }
  .diff-card { padding: 1.5rem 0; border-top: 3px solid var(--brand); }
  .diff-num { font-size: 0.9rem; font-weight: 800; color: var(--brand); font-family: var(--head-font); }
  .diff-card h3 { font-size: 1.4rem; margin-block: 0.5rem; }
  .diff-card p { color: var(--muted); }

  /* ---------- quote ---------- */
  .quote { padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .quote-inner { max-width: 780px; text-align: center; }
  .quote-mark { font-size: 5rem; line-height: 0.5; color: var(--brand); font-family: Georgia, serif; height: 2.5rem; }
  .quote blockquote { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; margin: 0; font-family: var(--head-font); letter-spacing: var(--head-tracking); line-height: 1.3; }
  .quote-by { color: var(--muted); margin-top: 1.25rem; font-weight: 600; }

  /* ---------- CTA band ---------- */
  .cta-band { background: var(--navy); color: #fff; padding-block: clamp(3rem, 6vw, 4.5rem); }
  .cta-inner { text-align: center; max-width: 640px; }
  .cta-band h2 { font-size: clamp(1.9rem, 4vw, 2.8rem); color: #fff; }
  .cta-band p { color: rgba(255, 255, 255, 0.8); margin-top: 0.75rem; margin-bottom: 1.75rem; font-size: 1.1rem; }

  /* ---------- footer ---------- */
  .site-foot { background: var(--foot-bg); color: var(--foot-ink); padding-block: 3rem 1.5rem; }
  .foot-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; padding-bottom: 2rem; }
  @media (max-width: 720px) { .foot-grid { grid-template-columns: 1fr; } }
  .foot-logo { font-family: var(--head-font); font-weight: 900; font-size: 1.3rem; color: #fff; }
  .foot-brand p { margin-top: 0.5rem; font-size: 0.95rem; }
  .foot-col h4 { color: #fff; font-size: 0.95rem; margin-bottom: 0.75rem; }
  .foot-col a { display: block; text-decoration: none; color: var(--foot-ink); font-size: 0.92rem; padding: 0.2rem 0; }
  .foot-col a:hover { color: var(--brand); }
  .foot-bottom { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.1); font-size: 0.85rem; }
  .foot-credit strong { color: #fff; }

  /* ---------- styleguide strip ---------- */
  .guide { background: var(--ink); color: #fff; padding-block: 3.5rem; }
  .guide .wrap > * { color: #fff; }
  .guide-head { margin-bottom: 2.5rem; }
  .guide-kicker { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--brand); }
  .guide-title { font-size: 2.2rem; font-weight: 900; margin-top: 0.4rem; }
