---
// Shared lower half for every design direction. Colours come ONLY from the
// [data-dir] tokens, so this renders correctly on light and dark themes alike.
// The hero (the signature) lives per-direction; this keeps the comparison fair.
interface Props {
  id: number;
  name: string;
  tagline: string;
  signature: string;
  palette: { hex: string; label: string }[];
  fontNote: string;
}
const { id, name, tagline, signature, palette, fontNote } = Astro.props;

const stats = [
  { big: '3,8×', label: 'gem. ROAS op Meta Ads' },
  { big: '+124', label: 'leads per maand' },
  { big: '40+', label: 'ondernemers geholpen' },
  { big: '€0', label: 'risico — garantie' },
];

const services = [
  { name: 'Meta Ads', tag: 'Hoofddienst', desc: 'Facebook & Instagram advertenties die jouw ideale klant bereiken en meetbaar leads opleveren.', caseName: 'PT Studio Amsterdam' },
  { name: 'Meekijksessie', tag: 'Done-with-you', desc: 'Live meekijken terwijl jij zelf de pixel en campagnes aanzet — mét de juiste instructies. Zo word je zelfredzaam.', caseName: 'Coach Rotterdam' },
  { name: 'SEO', tag: 'Groei', desc: 'Beter vindbaar in Google op de zoekwoorden waar jouw klanten écht op zoeken.', caseName: 'Sportschool Utrecht' },
  { name: 'Email Marketing', tag: 'Retentie', desc: 'Automatische flows die leads warm houden en klanten laten terugkomen.', caseName: 'PT Studio Amsterdam' },
  { name: 'Copywriting', tag: 'Conversie', desc: 'Teksten die overtuigen — van advertentie tot landingspagina.', caseName: 'Sportschool Utrecht' },
];

const cases = [
  { client: 'PT Studio Amsterdam', segment: 'Personal training', metric: '4,2× ROAS', sub: '+38 nieuwe klanten in 3 mnd', service: 'Meta Ads' },
  { client: 'Sportschool Utrecht', segment: 'Fitness', metric: '−41% kosten/lead', sub: 'Top-3 in Google lokaal', service: 'SEO' },
  { client: 'Coach Rotterdam', segment: 'Online coaching', metric: '32% meer omzet', sub: 'via e-mail automation', service: 'Email Marketing' },
];

const diffs = [
  { t: 'Garantie', d: 'Jij neemt niet al het risico — dat delen we. Een samenwerking moet win-win zijn.' },
  { t: 'Resultaat', d: 'Geen loze beloftes, maar meetbare groei. Focus op leads en omzet.' },
  { t: 'Persoonlijk', d: 'Korte lijnen, snelle communicatie. Geen accountmanager-carrousel.' },
  { t: 'Specialisatie', d: 'Geen allesdoeners. Experts in Meta Ads en SEO voor jouw niche.' },
];

const articles = [
  'Zo zet je de Meta Pixel in 10 minuten goed op',
  'Welk advertentiebudget heb je nodig als personal trainer?',
  'Van volgers naar klanten: de funnel voor sportscholen',
];
import './Sections.css';
---

<div class="sx">
  <!-- STATS -->
  <section class="stats">
    <div class="wrap stats-row">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat-big">{s.big}</span>
          <span class="stat-lab">{s.label}</span>
        </div>
      ))}
    </div>
    <p class="wrap ph-note">Voorbeeldcijfers — vervangen door echte cases bij oplevering.</p>
  </section>

  <!-- SERVICES → CASE -->
  <section class="services">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Diensten</span>
        <h2>Waar we het verschil maken</h2>
        <p class="sec-sub">Elke dienst is gekoppeld aan een echte case — je ziet meteen wat het oplevert.</p>
      </div>
      <div class="svc-grid">
        {services.map((s) => (
          <article class:list={['svc-card', { hero: s.tag === 'Hoofddienst' }]}>
            <span class="svc-tag">{s.tag}</span>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
            <a class="svc-link" href="#">Bekijk case: {s.caseName} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CASES → SERVICE -->
  <section class="cases">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Succesverhalen</span>
        <h2>Resultaten die tellen</h2>
        <p class="sec-sub">Elke case linkt terug naar de dienst die het mogelijk maakte.</p>
      </div>
      <div class="case-grid">
        {cases.map((c) => (
          <article class="case-card">
            <div class="case-top">
              <span class="case-seg">{c.segment}</span>
              <span class="case-metric">{c.metric}</span>
            </div>
            <h3>{c.client}</h3>
            <p class="case-sub">{c.sub}</p>
            <a class="case-service" href="#">Dienst: {c.service} →</a>
          </article>
        ))}
      </div>
      <p class="ph-note">Placeholder-cases — structuur staat, echte cijfers vult Lars in.</p>
    </div>
  </section>

  <!-- KENNISBANK + ZOEK -->
  <section class="kb">
    <div class="wrap kb-inner">
      <div class="kb-head">
        <span class="eyebrow">Kennisbank</span>
        <h2>Leer het zelf — of laat het ons doen</h2>
        <p class="sec-sub">Instructies en how-to's over Meta Ads, pixels en SEO. Doorzoekbaar.</p>
        <div class="kb-search" role="search">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <input type="search" placeholder="Zoek in de kennisbank…" readonly />
        </div>
      </div>
      <ul class="kb-list">
        {articles.map((a) => (
          <li><a href="#"><span class="kb-kicker">Instructie</span>{a}<span class="kb-arrow">→</span></a></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- DIFFERENTIATORS -->
  <section class="diffs">
    <div class="wrap">
      <div class="sec-head"><h2>"Oké, wat maakt jou anders?"</h2></div>
      <div class="diff-grid">
        {diffs.map((d) => (
          <div class="diff-card">
            <h3>{d.t}</h3>
            <p>{d.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="quote">
    <div class="wrap quote-inner">
      <blockquote>Sinds Meer Impact onze Meta Ads doet, komen er elke week nieuwe aanmeldingen binnen. Eindelijk marketing die gewoon leads oplevert.</blockquote>
      <p class="quote-by">— Voorbeeldklant, Personal Trainer</p>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta-band">
    <div class="wrap cta-inner">
      <h2>Klaar voor meer klanten?</h2>
      <p>Vraag een gratis marketinganalyse aan. Geen verplichtingen — wel een concreet plan.</p>
      <a href="#" class="btn btn-band">Gratis analyse aanvragen →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-foot">
    <div class="wrap foot-grid">
      <div class="foot-brand">
        <span class="foot-logo">Meer Impact Marketing</span>
        <p>Meta Ads &amp; SEO die groei opleveren.</p>
      </div>
      <div class="foot-col"><h4>Diensten</h4><a href="#">Meta Ads</a><a href="#">Meekijksessie</a><a href="#">SEO</a><a href="#">Email Marketing</a></div>
      <div class="foot-col"><h4>Bedrijf</h4><a href="#">Succesverhalen</a><a href="#">Kennisbank</a><a href="#">Contact</a><a href="#">Gratis guide</a></div>
    </div>
    <div class="wrap foot-bottom">
      <span>© 2026 Meer Impact Marketing</span>
      <span class="foot-credit">Website door <strong>Tielo Digital</strong> ◆</span>
    </div>
  </footer>

  <!-- STYLEGUIDE STRIP -->
  <section class="guide">
    <div class="wrap">
      <div class="guide-head">
        <span class="guide-kicker">Richting {id}</span>
        <h2 class="guide-title">{name}</h2>
        <p class="guide-tag">{tagline}</p>
        <p class="guide-sig"><strong>Signature:</strong> {signature}</p>
      </div>
      <div class="guide-block">
        <h5>Kleuren</h5>
        <div class="swatches">
          {palette.map((p) => (
            <div class="swatch">
              <span class="sw-chip" style={`background:${p.hex}`}></span>
              <span class="sw-hex">{p.hex}</span>
              <span class="sw-lab">{p.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="guide-block">
        <h5>Typografie <span class="guide-note">{fontNote}</span></h5>
        <p class="ts-h1">Meer Impact</p>
        <p class="ts-body">Bodytekst: helder, tutoyerend en resultaatgericht. Zo leest de hele site.</p>
      </div>
      <div class="guide-block">
        <h5>Componenten</h5>
        <div class="comp-row">
          <a href="#" class="btn btn-primary">Primaire knop</a>
          <a href="#" class="btn btn-ghost">Secundaire knop</a>
          <span class="badge"><i class="dot"></i> Badge</span>
          <span class="svc-tag">Label</span>
        </div>
      </div>
    </div>
  </section>
</div>

